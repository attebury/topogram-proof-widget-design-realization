shape shape_output_item_export_status {
  name "Item Export Status"
  description "Status payload for long-running item export jobs"

  fields {
    job_id uuid required
    status export_job_status required default accepted
    status_url text required
    submitted_at datetime required
    completed_at datetime optional
    expires_at datetime optional
    download_url text optional
    error_message text optional
  }

  status active
}
