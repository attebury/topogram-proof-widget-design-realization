shape shape_output_item_card from entity_item {
  name "Item Card Output"
  description "Compact item payload for cards and lists"
  include [title, status, priority, due_at, owner_id]

  rename {
    due_at dueAt
    owner_id ownerId
  }

  overrides {
    title optional
    status default active
    priority default medium
    ownerId required
  }

  status active
}
